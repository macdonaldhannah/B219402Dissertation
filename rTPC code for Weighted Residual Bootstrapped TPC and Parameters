#Get the derived parameters from the bootstrapped values 
get_derived_from_coefs <- function(a, b, c, tref) {
  
  # Search only within the observed data range to avoid extrapolation 
  temp_seq <- seq(3.2, 18.3, length.out = 100000)
  rate     <- thomas_2012(temp = temp_seq, a = a, b = b, c = c, tref = tref)
  
  topt     <- temp_seq[which.max(rate)]
  rmax     <- max(rate, na.rm = TRUE)
  positive <- rate > 0
  ctmax    <- if (any(positive)) max(temp_seq[positive]) else NA
  rate_at_T   <- thomas_2012(temp = 3.2,  a = a, b = b, c = c, tref = tref)
  rate_at_Topt <- thomas_2012(temp = topt, a = a, b = b, c = c, tref = tref)
  q10         <- (rate_at_Topt / rate_at_T)^(10/(topt - 3.2))
  above_80    <- rate >= (rmax * 0.8)
  niche_width <- if (any(above_80)) {
    max(temp_seq[above_80]) - min(temp_seq[above_80])
  } else NA
  
  return(data.frame(topt, rmax, ctmax, q10, niche_width))
}



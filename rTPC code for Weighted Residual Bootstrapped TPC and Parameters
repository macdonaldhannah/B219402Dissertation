#Get the derived parameters from the bootstrapped values 
get_derived_from_coefs <- function(a, b, c, tref) {
  
  # Search only within the observed data range to avoid extrapolation 
  temp_seq <- seq(3.2, 18.3, length.out = 100000)
  rate     <- thomas_2012(temp = temp_seq, a = a, b = b, c = c, tref = tref)
  
  topt     <- temp_seq[which.max(rate)]
  rmax     <- max(rate, na.rm = TRUE)
  positive <- rate > 0
  ctmax    <- if (any(positive)) max(temp_seq[positive]) else NA
  rate_at_T   <- thomas_2012(temp = 3.2,  a = a, b = b, c = c, tref = tref)
  rate_at_Topt <- thomas_2012(temp = topt, a = a, b = b, c = c, tref = tref)
  q10         <- (rate_at_Topt / rate_at_T)^(10/(topt - 3.2))
  above_80    <- rate >= (rmax * 0.8)
  niche_width <- if (any(above_80)) {
    max(temp_seq[above_80]) - min(temp_seq[above_80])
  } else NA
  
  return(data.frame(topt, rmax, ctmax, q10, niche_width))
}

cat("=== Light 50 ===\n")
get_derived_from_coefs(
  a    = coef(fit_nlsLM_50)['a'],
  b    = coef(fit_nlsLM_50)['b'],
  c    = coef(fit_nlsLM_50)['c'],
  tref = coef(fit_nlsLM_50)['tref']
) %>% print()

cat("=== Light 100 ===\n")
get_derived_from_coefs(
  a    = coef(fit_nlsLM_100)['a'],
  b    = coef(fit_nlsLM_100)['b'],
  c    = coef(fit_nlsLM_100)['c'],
  tref = coef(fit_nlsLM_100)['tref']
) %>% print()

#Bootstrap the derived parameters 

#50 PHOTONS 
boot_derived_50 <- boot_50$t %>%
  as.data.frame() %>%
  setNames(c('a', 'b', 'c', 'tref')) %>%
  drop_na() %>%
  mutate(iter = 1:n()) %>%
  rowwise() %>%
  mutate(derived = list(get_derived_from_coefs(a, b, c, tref))) %>%
  ungroup() %>%
  select(iter, derived) %>%
  unnest(derived) %>%
  mutate(light = 50)

#100 PHOTONS 
boot_derived_100 <- boot_100$t %>%
  as.data.frame() %>%
  setNames(c('a', 'b', 'c', 'tref')) %>%
  drop_na() %>%
  mutate(iter = 1:n()) %>%
  rowwise() %>%
  mutate(derived = list(get_derived_from_coefs(a, b, c, tref))) %>%
  ungroup() %>%
  select(iter, derived) %>%
  unnest(derived) %>%
  mutate(light = 100)

#Combined the derived data into one dataset 
boot_derived_all <- bind_rows(boot_derived_50, boot_derived_100)

#Check the successfl bootstraps 
boot_derived_all %>%
  group_by(light) %>%
  summarise(
    n_topt  = sum(!is.na(topt)),
    n_ctmax = sum(!is.na(ctmax)),
    n_rmax  = sum(!is.na(rmax)),
    n_q10         = sum(!is.na(q10)),
    n_niche_width = sum(!is.na(niche_width))
  )

#Calculate the CI's for the derived parameters 
derived_ci <- boot_derived_all %>%
  group_by(light) %>%
  summarise(
    topt_estimate  = mean(topt,  na.rm = TRUE),
    topt_lower     = quantile(topt,  0.025, na.rm = TRUE),
    topt_upper     = quantile(topt,  0.975, na.rm = TRUE),
    ctmax_estimate = mean(ctmax, na.rm = TRUE),
    ctmax_lower    = quantile(ctmax, 0.025, na.rm = TRUE),
    ctmax_upper    = quantile(ctmax, 0.975, na.rm = TRUE),
    rmax_estimate  = mean(rmax,  na.rm = TRUE),
    rmax_lower     = quantile(rmax,  0.025, na.rm = TRUE),
    rmax_upper     = quantile(rmax,  0.975, na.rm = TRUE),
    q10_estimate         = mean(q10,         na.rm = TRUE),
    q10_lower            = quantile(q10,         0.025, na.rm = TRUE),
    q10_upper            = quantile(q10,         0.975, na.rm = TRUE),
    niche_width_estimate = mean(niche_width, na.rm = TRUE),
    niche_width_lower    = quantile(niche_width, 0.025, na.rm = TRUE),
    niche_width_upper    = quantile(niche_width, 0.975, na.rm = TRUE)
  )

print(derived_ci,  width = Inf)

#Make comparative plots for the derived parameters 

#Define custom panel labels
param_labels <- c(
  topt  = 'Topt (°C)',
  ctmax = 'Tmax (°C)',
  rmax  = 'μmax (day-1)',
  q10         = 'Q10',
  niche_width = 'Niche Width (°C)'
)

boot_derived_all %>%
  pivot_longer(cols = c(topt, ctmax, rmax, q10, niche_width),
               names_to  = 'parameter',
               values_to = 'value') %>%
  ggplot(aes(factor(light), value, fill = factor(light))) +
  geom_violin(alpha = 0.4, trim = FALSE) +
  geom_boxplot(width = 0.1, outlier.shape = NA, aes(col = factor(light))) +
  facet_wrap(~parameter, scales = 'free_y',
             labeller = labeller(parameter = param_labels)) +
  scale_fill_manual(values = c('50' = 'blue', '100' = 'red')) +
  scale_colour_manual(values = c('50' = 'blue', '100' = 'red')) +
  theme_bw(base_size = 12) +
  labs(
    x    = 'Light Intensity',
    y    = 'Parameter value',
    fill = 'Light Intensity
     (μmol photons m-2 s-1)',
    col  = 'Light Intensity
     (μmol photons m-2 s-1)'
  )


saveRDS(boot_derived_all, file = "boot_derived_TPC1.rds")

#Calculate bootstrap difference intervals between light treatments
boot_diff <- boot_derived_all %>%
  pivot_longer(cols = c(topt, ctmax, rmax, q10, niche_width),
               names_to  = 'parameter',
               values_to = 'value') %>%
  pivot_wider(names_from  = light,
              values_from = value,
              names_prefix = 'light_') %>%
  unnest(c(light_50, light_100)) %>%
  mutate(difference = light_100 - light_50) %>%
  group_by(parameter) %>%
  summarise(
    mean_diff    = mean(difference,               na.rm = TRUE),
    lower        = quantile(difference, 0.025,    na.rm = TRUE),
    upper        = quantile(difference, 0.975,    na.rm = TRUE),
    crosses_zero = lower < 0 & upper > 0,
    .groups      = 'drop'
  ) %>%
  mutate(across(where(is.numeric), round, 3))

print(boot_diff)

saveRDS(boot_diff, file = "boot_diff_TPC1.rds")


#Quantifying the CI overlaps rather than t-test as bootstrap t-tests will provide unrealistic data 

#Calculate bootstrap difference intervals between light treatments
boot_diff <- boot_derived_all %>%
  pivot_longer(cols = c(topt, ctmax, rmax, q10, niche_width),
               names_to  = 'parameter',
               values_to = 'value') %>%
  pivot_wider(names_from  = light,
              values_from = value,
              names_prefix = 'light_') %>%
  unnest(c(light_50, light_100)) %>%
  mutate(difference = light_100 - light_50) %>%
  group_by(parameter) %>%
  summarise(
    mean_diff    = mean(difference,               na.rm = TRUE),
    lower        = quantile(difference, 0.025,    na.rm = TRUE),
    upper        = quantile(difference, 0.975,    na.rm = TRUE),
    crosses_zero = lower < 0 & upper > 0,
    .groups      = 'drop'
  ) %>%
  mutate(across(where(is.numeric), round, 3))


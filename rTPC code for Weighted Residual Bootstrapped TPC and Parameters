#Fitting the Norberg model using rTPC 

#load packages
library(remotes)
remotes::install_github("padpadpadpad/rTPC")
library(rTPC)
library(nls.multstart)
library(minpack.lm)
library(car)
library(broom)
library(tidyverse)
library(dplyr)
library(patchwork)
conflicted::conflicts_prefer(dplyr::select)
conflicted::conflicts_prefer(dplyr::filter)

#Plot my data
ggplot(combined_TPC1, aes(temperature, growth, col = factor(light))) +
  geom_point() +
  theme_bw(base_size = 12) +
  labs(
    x = 'Temperature (ºC)',
    y = 'Specific Growth Rate μ (day-1)',
    col = 'Light Intensity'
  )

#Check structure - check if i am fitting the TPC through the replicates - n > 0 = YES
combined_TPC1 %>%
  group_by(light, temperature) %>%
  summarise(n = n(), .groups = "drop") %>%
  print(n = Inf)

#Variance per temperature per light - this checks what bootstrapping approach to use based on variance - HERE = WEIGHTED 
combined_TPC1 %>%
  group_by(light, temperature) %>%
  summarise(
    mean_growth = mean(growth),
    sd_growth   = sd(growth),
    cv          = sd_growth / abs(mean_growth) * 100,  # coefficient of variation %
    .groups = "drop"
  ) %>%
  print(n = Inf)

#Calculate the SD for the replicates 
combined_TPC1 <- combined_TPC1 %>%
  group_by(light, temperature) %>%
  mutate(sd_growth = sd(growth, na.rm = TRUE)) %>%
  ungroup()

#Split data by light level 
data_50 <- filter(combined_TPC1, light ==50)
data_100 <- filter (combined_TPC1, light == 100)

#Fit nls_mulstart to get the starting values for each light level 
#50 PHOTONS 
nls_fit_50 <- nls_multstart(
  growth ~ thomas_2012(temp = temperature, a, b, c, tref),
  data = data_50,
  iter = c(4,4,4,4),
  start_lower = get_start_vals(data_50$temperature, data_50$growth, model_name = 'thomas_2012') - 1,
  start_upper = get_start_vals(data_50$temperature, data_50$growth, model_name = 'thomas_2012') + 2,
  lower = get_lower_lims(data_50$temperature, data_50$growth, model_name = 'thomas_2012'),
  upper = get_upper_lims(data_50$temperature, data_50$growth, model_name = 'thomas_2012'),
  supp_errors = 'Y',
  convergence_count = FALSE,
  modelweights = 1/data_50$sd_growth
)

#100 PHOTONS 
nls_fit_100 <- nls_multstart(
  growth ~ thomas_2012(temp = temperature, a, b, c, tref),
  data = data_100,
  iter = c(4,4,4,4),
  start_lower = get_start_vals(data_100$temperature, data_100$growth, model_name = 'thomas_2012') - 1,
  start_upper = get_start_vals(data_100$temperature, data_100$growth, model_name = 'thomas_2012') + 2,
  lower = get_lower_lims(data_100$temperature, data_100$growth, model_name = 'thomas_2012'),
  upper = get_upper_lims(data_100$temperature, data_100$growth, model_name = 'thomas_2012'),
  supp_errors = 'Y',
  convergence_count = FALSE,
  modelweights = 1/data_100$sd_growth
)

#Check the summaries 
summary(nls_fit_50)
summary(nls_fit_100)

#Calculate TPC parameters 
params_50  <- calc_params(nls_fit_50)  %>% mutate(light = 50)
params_100 <- calc_params(nls_fit_100) %>% mutate(light = 100)
params_all <- bind_rows(params_50, params_100)
print(params_all)

#Get predictions to fit a curve in the TPC
temp_seq_50  <- data.frame(temperature = seq(min(data_50$temperature),
                                             max(data_50$temperature),
                                             length.out = 100))
temp_seq_100 <- data.frame(temperature = seq(min(data_100$temperature),
                                             max(data_100$temperature),
                                             length.out = 100))

preds_50  <- augment(nls_fit_50,  newdata = temp_seq_50)  %>% mutate(light = 50)
preds_100 <- augment(nls_fit_100, newdata = temp_seq_100) %>% mutate(light = 100)
preds_all <- bind_rows(preds_50, preds_100)

#Plot the curves for both light intensities 
ggplot() +
  geom_point(aes(temperature, growth, col = factor(light)), data = combined_TPC1) +
  geom_line(aes(temperature, .fitted, col = factor(light)), data = preds_all) +
  theme_bw(base_size = 12) +
  labs(
    x = 'Temperature (ºC)',
    y = 'Specific Growth Rate μ (day-1)',
    col = 'Light Intensity'
  )

#Convert the nls_mulstart into a usable format for bootstrapping 
fit_nlsLM_50 <- nlsLM(
  growth ~ thomas_2012(temp = temperature, a, b, c, tref),
  data = data_50,
  start = coef(nls_fit_50),
  lower = get_lower_lims(data_50$temperature, data_50$growth, model_name = 'thomas_2012'),
  upper = get_upper_lims(data_50$temperature, data_50$growth, model_name = 'thomas_2012'),
  weights = 1 / data_50$sd_growth
)

fit_nlsLM_100 <- nlsLM(
  growth ~ thomas_2012(temp = temperature, a, b, c, tref),
  data = data_100,
  start = coef(nls_fit_100),
  lower = get_lower_lims(data_100$temperature, data_100$growth, model_name = 'thomas_2012'),
  upper = get_upper_lims(data_100$temperature, data_100$growth, model_name = 'thomas_2012'),
  weights = 1 / data_100$sd_growth
)

#Extract residuals
residuals_50 <- residuals(fit_nlsLM_50)
residuals_100 <- residuals(fit_nlsLM_100)

#Test normality of mean residuals per temperature
mean_resid_50 <- data.frame(
  temperature = data_50$temperature,
  residual = residuals_50) %>%
  group_by(temperature) %>%
  summarise(mean_resid = mean(residual), .groups = 'drop')

cat("=== Normality of Mean Residuals 50 µmol ===\n")
print(shapiro.test(mean_resid_50$mean_resid))

mean_resid_100 <- data.frame(
  temperature = data_100$temperature,
  residual = residuals_100) %>%
  group_by(temperature) %>%
  summarise(mean_resid = mean(residual), .groups = 'drop')

cat("=== Normality of Mean Residuals 100 µmol ===\n")
print(shapiro.test(mean_resid_100$mean_resid))

#Fit the bootstrap 
set.seed(42)
boot_50  <- Boot(fit_nlsLM_50,  method = 'residual', R = 999)
boot_100 <- Boot(fit_nlsLM_100, method = 'residual', R = 999)

#Check the successful bootstraps 
nrow(boot_50$t[complete.cases(boot_50$t), ])
nrow(boot_100$t[complete.cases(boot_100$t), ])

#Bootstrap the predictions to fit the curve confidence intervals (CI's)
boot_preds_50 <- boot_50$t %>%
  as.data.frame() %>%
  drop_na() %>%
  mutate(iter = 1:n()) %>%
  group_by(iter) %>%
  reframe(
    temperature = temp_seq_50$temperature,
    fitted = thomas_2012(temp = temp_seq_50$temperature, a, b, c, tref)
  ) %>%
  group_by(temperature) %>%
  summarise(
    lower_ci = quantile(fitted, 0.025, na.rm = TRUE),
    upper_ci = quantile(fitted, 0.975, na.rm = TRUE),
    .groups = 'drop'
  ) %>%
  mutate(light = 50)

boot_preds_100 <- boot_100$t %>%
  as.data.frame() %>%
  drop_na() %>%
  mutate(iter = 1:n()) %>%
  group_by(iter) %>%
  reframe(
    temperature = temp_seq_100$temperature,
    fitted = thomas_2012(temp = temp_seq_100$temperature, a, b, c, tref)
  ) %>%
  group_by(temperature) %>%
  summarise(
    lower_ci = quantile(fitted, 0.025, na.rm = TRUE),
    upper_ci = quantile(fitted, 0.975, na.rm = TRUE),
    .groups = 'drop'
  ) %>%
  mutate(light = 100)

boot_preds_all <- bind_rows(boot_preds_50, boot_preds_100)

#Final bootstrapped plot with CI's
ggplot() +
  geom_ribbon(aes(temperature, ymin = lower_ci, ymax = upper_ci, fill = factor(light)),
              data = boot_preds_all, alpha = 0.2) +
  geom_point(aes(temperature, growth, col = factor(light)),
                        data = combined_TPC1) +          
  geom_line(aes(temperature, .fitted, col = factor(light)),
            data = preds_all) +
  geom_hline(yintercept = 0, linetype = 'solid', colour = 'black', linewidth = 0.5) +
  scale_x_continuous(breaks = seq(0, 20, by = 5),
                     limits = c(0, 20),
                     expand = c(0, 0)) +
  scale_colour_manual(values = c('50' = 'blue', '100' = 'red')) +  
  scale_fill_manual(values   = c('50' = 'blue', '100' = 'red')) +  
  theme_bw(base_size = 12) +
  labs(
    x = 'Temperature (ºC)',
    y = 'Specific Growth Rate μ (day-1)',
    col = 'Light Intensity 
    (μmol photons m-2 s-1)',
    fill = 'Light Intensity 
    (μmol photons m-2 s-1)'
  )


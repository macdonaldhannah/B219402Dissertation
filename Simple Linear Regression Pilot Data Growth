#Simple linear regression for pilot data 

#T1 PLOT -replicate 1
t1fluo <- T1_trf1
#this renames my data frame for ease

t1fluo$lnfluo <- log(t1fluo$fluorescence)
#this log transforms all my data to get the exponential 

rep1 <-subset(t1fluo, replicate == 1)
rep1
#this subsets my data for the replicate that i want

model_rep1 <- lm(lnfluo ~ day, data = rep1)
summary(model_rep1)
coef(model_rep1)
#this takes the linear regression of replicate one and the coef for growth rate

#Replicate 2
rep2 <-subset(t1fluo, replicate == 2)
rep2
#this subsets my data for the replicate that i want

model_rep2 <- lm(lnfluo ~ day, data = rep2)
summary(model_rep2)
coef(model_rep2)

#Creating a LOOP for quickness 
for (r in 1:5) {
  print(
    coef(lm(lnfluo ~ day, data = subset(t1fluo, replicate == r)))["day"]
  )
}

